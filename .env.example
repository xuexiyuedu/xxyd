# 环境变量模板 - 复制为 .env.local 并填入真实值
#
# 启动顺序建议：
# 1. 本地开发：保持 NEXT_PUBLIC_MOCK_AUTH=true，无需真实 Supabase/COS 即可体验全部功能
# 2. 接入真实环境：将 NEXT_PUBLIC_MOCK_AUTH 改为 false，填入真实 Supabase/COS 凭证
# 3. 生产部署：所有密钥通过部署平台（Vercel/CloudBase）的环境变量配置，不写入代码

# ============ Mock 模式开关 ============
# true  = 使用内存 Mock 数据，零配置即可启动（适合开发/演示）
# false = 使用真实 Supabase + COS
NEXT_PUBLIC_MOCK_AUTH=true

# ============ Supabase ============
# 在 https://supabase.com 项目设置 → API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============ 腾讯云 COS ============
# 在 https://console.cloud.tencent.com/cos 创建存储桶后获取
NEXT_PUBLIC_COS_REGION=ap-guangzhou
NEXT_PUBLIC_COS_BUCKET=your-bucket-name-1234567890
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key

# ============ 应用配置 ============
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============ 翻译 API（有道翻译） ============
# 在 https://ai.youdao.com 控制台申请
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_APP_SECRET=your_youdao_app_secret

# ============ 微信支付（P1 阶段，可选） ============
# 在 https://pay.weixin.qq.com 商户平台获取
WECHAT_PAY_APP_ID=your_wechat_app_id
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial_no
WECHAT_PAY_PRIVATE_KEY=your_private_key
